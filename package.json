{
  "name": "@skillsmanager/cli",
  "version": "0.0.6",
  "description": "Discover, fetch, and manage agent skills from local or remote storage",
  "type": "module",
  "bin": {
    "skillsmanager": "dist/index.js"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "claude",
    "codex",
    "cursor",
    "copilot",
    "gemini",
    "registry",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talktoajayprakash/skillsmanager.git"
  },
  "author": "Ajay Prakash",
  "license": "Apache-2.0",
  "homepage": "https://github.com/talktoajayprakash/skillsmanager#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "googleapis": "^144.0.0",
    "ora": "^5.4.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
