{
  "name": "skillsync",
  "version": "0.1.0",
  "description": "Discover, fetch, and manage agent skills from remote storage",
  "type": "module",
  "bin": {
    "skillsync": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "googleapis": "^144.0.0",
    "ora": "^5.4.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
